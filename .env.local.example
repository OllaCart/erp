# App URL (must match Google Cloud "Authorized redirect URIs")
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — Link Gmail (Settings → Linked accounts)
# Create credentials: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
