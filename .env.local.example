NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Anthropic (Claude brain) ──────────────────────────────────────────────────
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Supabase (structured data: tasks, emails, events, transactions) ───────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth (multi-account Gmail + Calendar) ─────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Wiki memory (filesystem-first; see wiki/schema.md) ───────────────────────
# When unset or any value except "false", Claude uses wiki/pages/*.md for MEMORY CONTEXT if present.
USE_WIKI_MEMORY=
# Set to 1 to append non-canonical injection logs to wiki/.cache/context-injections.jsonl (local dev; may fail on read-only serverless FS)
WIKI_OBSERVABILITY=

# ── Neo4j (graph memory + relationships) ─────────────────────────────────────
# Used as fallback when wiki is disabled or has no pages, and for graph APIs.
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# ── GitHub (Dev module: webhooks, repo sync, .cursorrules) ───────────────────
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ── GoHighLevel (CRM for SwiftFi + UnbeatableLoans) ──────────────────────────
GHL_API_KEY_SWIFTFI=
GHL_API_KEY_UNBEATABLELOANS=
GHL_WEBHOOK_SECRET=

# ── LinkedIn (Social module) ──────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── OpenAI (optional — goal task generator only) ─────────────────────────────
OPENAI_API_KEY=
